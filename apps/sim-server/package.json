{
  "name": "@many-lives/sim-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "start": "node --import tsx src/index.ts",
    "test": "vitest run",
